{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"files": {
		"includes": [
			"**",
			"!node_modules",
			"!.pi",
			"!.tree",
			"!_tmp",
			"!_tmp *"
		],
		"ignoreUnknown": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 72
	},
	"linter": {
		"enabled": true,
		"rules": {
			"suspicious": {
				"noControlCharactersInRegex": "off"
			}
		}
	}
}
